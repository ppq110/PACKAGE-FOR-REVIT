    {
      "ConcreteType": "CoreNodeModels.Input.StringInput, CoreNodeModels",
      "Id": "e1f438374887476d83037890acf564a9",
      "NodeType": "StringInputNode",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "941d793376c947088ee5117c99fd0676",
          "Name": "",
          "Description": "String",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Creates a string",
      "InputValue": "Diameter(Ø)_Pile"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "import clr\r\n\r\n# Revit API\r\nclr.AddReference(\"RevitAPI\")\r\nfrom Autodesk.Revit.DB import *\r\n\r\n# Dynamo Geometry\r\nclr.AddReference(\"ProtoGeometry\")\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\n# Dynamo Revit\r\nclr.AddReference(\"RevitNodes\")\r\nimport Revit\r\nclr.ImportExtensions(Revit.Elements)\r\n\r\ncad = UnwrapElement(IN[0])\r\n\r\nlayerNames = IN[1]\r\n\r\nif layerNames is None:\r\n    layerNames = []\r\n\r\nif not isinstance(layerNames, list):\r\n    layerNames = [layerNames]\r\n\r\nopt = Options()\r\ngeo = cad.get_Geometry(opt)\r\n\r\nlayerDict = {}\r\n\r\n# chống trùng Circle\r\ncircleKeys = set()\r\n\r\ndef addCircle(layer, circle):\r\n\r\n    if layer not in layerDict:\r\n        layerDict[layer] = []\r\n\r\n    layerDict[layer].append(circle)\r\n\r\ndef walk(geoSet):\r\n\r\n    for g in geoSet:\r\n\r\n        if isinstance(g, GeometryInstance):\r\n\r\n            walk(g.GetInstanceGeometry())\r\n\r\n        else:\r\n\r\n            try:\r\n\r\n                style = cad.Document.GetElement(g.GraphicsStyleId)\r\n\r\n                if style is None:\r\n                    continue\r\n\r\n                layer = style.GraphicsStyleCategory.Name\r\n\r\n                if layerNames and layer not in layerNames:\r\n                    continue\r\n\r\n                # Chỉ lấy Arc\r\n                if g.GetType().Name != \"Arc\":\r\n                    continue\r\n\r\n                center = g.Center\r\n\r\n                # feet -> mm\r\n                x = center.X * 304.8\r\n                y = center.Y * 304.8\r\n                z = center.Z * 304.8\r\n\r\n                radius = g.Radius * 304.8\r\n\r\n                # loại bỏ Arc trùng tâm\r\n                key = (\r\n                    round(x,3),\r\n                    round(y,3),\r\n                    round(z,3),\r\n                    round(radius,3)\r\n                )\r\n\r\n                if key in circleKeys:\r\n                    continue\r\n\r\n                circleKeys.add(key)\r\n\r\n                pt = Point.ByCoordinates(x,y,z)\r\n\r\n                dsCircle = Circle.ByCenterPointRadius(\r\n                    pt,\r\n                    radius\r\n                )\r\n\r\n                addCircle(layer, dsCircle)\r\n\r\n            except:\r\n                pass\r\n\r\nwalk(geo)\r\n\r\n# xuất giống Bimorph\r\nlayerKeys = sorted(layerDict.keys())\r\n\r\ncurveGroups = []\r\n\r\nfor k in layerKeys:\r\n    curveGroups.append(layerDict[k])\r\n\r\nOUT = curveGroups",
      "Engine": "CPython3",
      "EngineName": "CPython3",
      "VariableInputPorts": true,
      "Id": "23db8e006bdd4a059f9e4d34100d51ec",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "3f7b2bd51c92418aa847446de7a72dce",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "f77471ce4433408caa3bb89cbdf369f7",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "37fa6cbacd204a9a8eea229b5efdcd52",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    }
  ],
